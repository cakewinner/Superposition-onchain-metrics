# ── Required ──────────────────────────────────────────────────────────────────

# Ethereum JSON-RPC endpoint (used for TVL in both modes)
# Must support ≥25k block ranges for on-chain mode (eth.llamarpc.com works)
ETH_RPC_URL=https://eth.llamarpc.com

# ── API mode (fast, ~5 s) ─────────────────────────────────────────────────────
# If API_BASE is set the script uses the Barter API for volume/fees/LP list.
# Only the chain is used for TVL (4 calls × n LPs).
# Leave unset to use on-chain mode instead.
#
# API_BASE=https://superposition.barterswap.xyz/<chainId>/transactions/<positionId>

# ── On-chain mode (no API needed, ~60 s) ──────────────────────────────────────
# Scans Approval events to find LP wallets and decodes router calldata for fees.
# Works with any standard Ethereum RPC.

# SuperpositionVault — address LPs approve USDC/USDT to (default already correct)
VAULT_ADDRESS=0x69355223a0ce30aee41d353387c3082e5aafc4da

# Block to start scanning from (vault deploy block)
START_BLOCK=23727155

# Blocks per eth_getLogs request — 25000 works on eth.llamarpc.com
CHUNK_SIZE=25000
